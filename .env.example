# Auth / actor identity used by Streamlit and API audit logs
APP_API_KEY=dev_user

# Frontend deployment:
# - local dev defaults to http://localhost:8000
# - deployed frontend defaults to same-origin /api proxy
# Optional direct browser-to-backend override:
VITE_API_BASE_URL=

# Vercel same-origin proxy target for /api/* requests.
# Set this in your Vercel project environment variables to the FastAPI backend base URL.
BACKEND_API_URL=

# LLM provider selection: azure|openai
AI_PROVIDER=azure

# Azure OpenAI (primary)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=

# OpenAI fallback (used when Azure is not configured)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
